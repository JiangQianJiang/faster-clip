# 将此文件复制为 .env 并填入真实值
# cp .env.example .env

# ASR 语音识别
DEFAULT_ASR_PROVIDER=qwen            # whisper_api 或 qwen
QWEN_POLL_TIMEOUT=600
# 服务端统一 setting 文件；默认 data/settings.json
# 可从 data/settings.example.json 复制后填入真实值
# APP_SETTINGS_PATH=/run/secrets/faster-clip-settings.json

# 安全
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=
# 访问令牌 — 至少 32 字符的高熵随机值; 可选（不设置则无需认证）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ACCESS_TOKEN=

# FFmpeg
FFMPEG_TIMEOUT=600
FONTS_DIR=/usr/share/fonts

# Redis
REDIS_URL=redis://redis:6379/0

# Database: MySQL is the default production/local Docker path
MYSQL_DATABASE=fasterclip
MYSQL_USER=fasterclip
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=root-password
MYSQL_PORT=3306
DATABASE_ENGINE=mysql
DATABASE_URL=mysql+pymysql://fasterclip:password@mysql:3306/fasterclip

# SQLite fallback, local/test only
# DATABASE_ENGINE=sqlite
# DATABASE_URL=sqlite:///data/live-clipper.db
# DATABASE_PATH=data/live-clipper.db

# Optional local MySQL integration tests
# MYSQL_TEST_DATABASE_URL=mysql+pymysql://fasterclip:password@127.0.0.1:3306/fasterclip_test

# 开发模式
DEBUG=true
