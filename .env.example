# 将此文件复制为 .env 并填入真实值
# cp .env.example .env

# ASR 语音识别
DEFAULT_ASR_PROVIDER=qwen            # whisper_api 或 qwen
QWEN_POLL_TIMEOUT=600

# 安全
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=
# 访问令牌 — 至少 32 字符的高熵随机值; 可选（不设置则无需认证）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ACCESS_TOKEN=

# FFmpeg
FFMPEG_TIMEOUT=600
FONTS_DIR=/usr/share/fonts

# Redis
REDIS_URL=redis://redis:6379/0

# SQLite
DATABASE_PATH=data/live-clipper.db

# 开发模式
DEBUG=true
